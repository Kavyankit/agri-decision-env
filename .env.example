# Copy to `.env` and fill in values. `.env` is gitignored — never commit secrets.
#
# cp .env.example .env
# then edit .env

# Required for `scripts/openai_baseline.py` (OpenAI client).
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Base URL of the FastAPI app (local or deployed Space).
# Used by the baseline script to call /tasks and /baseline endpoints.

# Local example:
# OPENENV_BASE_URL=http://127.0.0.1:7860

# Deployed Space (current):
OPENENV_BASE_URL=https://kavyankit-agri-decision-openenv.hf.space

# Optional server config (used by python main.py)
# APP_HOST=0.0.0.0
# APP_PORT=7860